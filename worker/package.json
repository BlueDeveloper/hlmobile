{
  "name": "hlmobile-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create hlmobile-db",
    "db:migrate": "wrangler d1 execute hlmobile-db --file=src/schema.sql --remote",
    "db:migrate:local": "wrangler d1 execute hlmobile-db --file=src/schema.sql --local",
    "db:seed": "wrangler d1 execute hlmobile-db --file=src/seed.sql --remote",
    "db:seed:local": "wrangler d1 execute hlmobile-db --file=src/seed.sql --local"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1"
  }
}
